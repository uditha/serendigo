# Root .env.example — see app-specific files for all variables:
#
#   apps/api/.env.example     — API server (Postgres / Supabase pooler, Redis, Auth, R2)
#   apps/mobile/.env.example  — Expo mobile (API URL; optional Supabase public keys)
#   apps/admin/.env.example   — Admin panel (Drizzle → same DB as API)
#
# Quick setup:
#   cp apps/api/.env.example apps/api/.env
#   cp apps/mobile/.env.example apps/mobile/.env
#   cp apps/admin/.env.example apps/admin/.env
