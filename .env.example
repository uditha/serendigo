# Root .env.example — see app-specific files for all variables:
#
#   apps/api/.env.example     — API server (DB, Redis, Auth, Payments, Storage)
#   apps/mobile/.env.example  — Expo mobile (API URL, Supabase public keys)
#   apps/admin/.env.example   — Admin / Payload CMS
#
# Quick setup:
#   cp apps/api/.env.example apps/api/.env
#   cp apps/mobile/.env.example apps/mobile/.env
#   cp apps/admin/.env.example apps/admin/.env
