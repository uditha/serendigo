# ── API ───────────────────────────────────────────────────────────────────────
# Local dev: use your machine's LAN IP — device cannot reach "localhost"
# Find it with: ipconfig (Windows) / ifconfig (Mac/Linux)
EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# ── Supabase (optional — public keys only) ─────────────────────────────────────
# The app uses EXPO_PUBLIC_API_URL for data. Add these only if you integrate
# @supabase/supabase-js in the client (e.g. Realtime). Never put the service_role key here.
EXPO_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
