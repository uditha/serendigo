# ── Payload CMS ───────────────────────────────────────────────────────────────
PAYLOAD_SECRET=change-me-to-a-random-string
PAYLOAD_URL=http://localhost:3001

# ── Database (same Supabase instance as API) ──────────────────────────────────
DATABASE_URI=postgresql://postgres:[password]@[host].supabase.co:5432/postgres

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=serendigo-media
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
