# ── Admin Auth ────────────────────────────────────────────────────────────────
# Set to any long random string — used to verify /login form submission
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Database (same Supabase Postgres instance as API) ─────────────────────────
# Supabase → Project Settings → Database → "Transaction pooler" (port 6543).
# Include ?pgbouncer=true on the pooler host. Never commit a real password.
# DATABASE_URL="postgresql://postgres.fnsqcimhicxzzjpgebba:YOUR_DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get key from resend.com — used for creator approval/rejection emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=SerendiGO <creators@serendigo.app>

# ── Creator portal URL (for email links) ──────────────────────────────────────
NEXT_PUBLIC_CREATOR_PORTAL_URL=https://serendigo.app
