# ── Admin Auth ────────────────────────────────────────────────────────────────
# Set to any long random string — used to verify /login form submission
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Database (same Supabase Postgres instance as API) ─────────────────────────
# Supabase → Project Settings → Database → copy "Transaction pooler" connection string.
# Use placeholders only in git — never commit a real password.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
