# ── Database (Supabase Postgres) ───────────────────────────────────────────────
# Use the connection string from Supabase → Project Settings → Database.
# Prefer the "Transaction pooler" URI (port 6543) for serverless / many short connections.
# Example shape (replace [password] and host with yours; keep ssl if shown):
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
#
# SerendiGO talks to Postgres via Drizzle (this URL). Row Level Security is enabled on
# public tables so the PostgREST API is not open by default; do not rely on the anon key
# for backend access — keep using DATABASE_URL from the server only.

# ── Supabase REST (optional — only if you add @supabase/supabase-js on the API) ─
# Never expose SUPABASE_SERVICE_ROLE_KEY to browsers or the mobile app.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cache / Queue (Upstash Redis) ────────────────────────────────────────────
REDIS_URL=rediss://default:[token]@[endpoint].upstash.io:6379
UPSTASH_REDIS_REST_URL=https://[endpoint].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-string
BETTER_AUTH_URL=http://localhost:3000

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYHARE_MERCHANT_ID=
PAYHARE_SECRET=

# ── Storage (Cloudflare R2 + Images) ─────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=serendigo-media
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_IMAGES_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Set to your LAN IP so mobile can load locally uploaded photos in dev
API_BASE_URL=http://192.168.86.22:3000

# Skip GPS radius check during local development (set to false in production)
SKIP_LOCATION_CHECK=true
