# ── Database (Supabase Postgres) ───────────────────────────────────────────────
# Supabase → Project Settings → Database.
#
# If you see CONNECT_TIMEOUT to *.pooler.supabase.com:6543 (VPN, corporate Wi‑Fi, or
# flaky routes), use the direct connection instead: "Connection string" URI with host
# db.<project-ref>.supabase.co and port 5432 (user is often `postgres`, not postgres.<ref>).
# The API auto-sets prepare=false only for the pooler / ?pgbouncer=true.
#
# Transaction pooler (many serverless hosts; requires prepare: false):
# DATABASE_URL="postgresql://postgres.fnsqcimhicxzzjpgebba:YOUR_DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# Direct (often more reliable for local bun dev):
# DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.fnsqcimhicxzzjpgebba.supabase.co:5432/postgres"
#
# SerendiGO talks to Postgres via Drizzle (this URL). RLS is enabled on public tables;
# keep this URL on the server only — never the anon key for backend access.

# ── Supabase REST (optional — only if you add @supabase/supabase-js on the API) ─
# Never expose SUPABASE_SERVICE_ROLE_KEY to browsers or the mobile app.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cache / Queue (Upstash Redis) ────────────────────────────────────────────
REDIS_URL=rediss://default:[token]@[endpoint].upstash.io:6379
UPSTASH_REDIS_REST_URL=https://[endpoint].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-64-char-string

# ── Google OAuth (for mobile Google Sign-In) ─────────────────────────────────
# Google Cloud Console → Credentials → Web Client ID + Secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the URL the mobile app uses (EXPO_PUBLIC_API_URL). For a physical device, use your LAN IP (same as API_BASE_URL below), not localhost — otherwise sign-in returns "Invalid origin".
BETTER_AUTH_URL=http://localhost:3000
# Optional comma-separated extra origins (admin web, staging). BETTER_AUTH_URL and API_BASE_URL are always trusted.
# TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYHARE_MERCHANT_ID=
PAYHARE_SECRET=

# ── Storage (Cloudflare R2 + Images) ─────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=serendigo-media
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_IMAGES_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Set to your LAN IP so mobile can load locally uploaded photos in dev
API_BASE_URL=http://192.168.86.22:3000

# Skip GPS radius check during local development (set to false in production)
SKIP_LOCATION_CHECK=true
